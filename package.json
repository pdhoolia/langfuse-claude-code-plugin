{
  "name": "langfuse-claude-code-plugin",
  "version": "0.1.0",
  "description": "Langfuse observability plugin for tracing Claude Code conversations",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && pnpm bundle",
    "bundle": "node esbuild.config.mjs",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "langfuse": "^3.35.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.7",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
